# Secrets and optional credentials.
#
# Most users only need one of these:
# - `SWARM_VAULT_PASSPHRASE` for local auth capture
# - `SWARM_VAULT_PASSPHRASE_FILE` on RunPod or another remote GPU host

# Recommended for local use
SWARM_VAULT_PASSPHRASE=

# Recommended for RunPod / remote hosts
SWARM_VAULT_PASSPHRASE_FILE=

# Optional: if you want the RunPod entrypoint to install your SSH key
SSH_PUBLIC_KEY=

# Optional: API-key fallback mode instead of ChatGPT/Codex cached auth
OPENAI_API_KEY=

# Everything else should be configured in:
# - `config/swarm.yaml`
# - `runpod/pod-template.json`
