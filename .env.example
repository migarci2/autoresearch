# Main local env file.
#
# Use this only for the Compose fallback on your own machine.
# RunPod does not need this file; Pod env vars live in `runpod/pod-template.json`
# and in the RunPod UI.

# Docker / Compose
COMPOSE_PROJECT_NAME=autoresearch
AUTORESEARCH_BASE_IMAGE_NAME=autoresearch-mnist-base:cuda128
AUTORESEARCH_IMAGE_NAME=autoresearch-mnist:cuda128
UID=1000
GID=1000

# Runtime
CUDA_VISIBLE_DEVICES=all
DASHBOARD_PORT=8080

# Base image build only.
# Compose builds the thin app image and does not consume this directly.
NODE_MAJOR=22

# Everything else now lives in:
# - `config/swarm.yaml` for swarm behavior
# - `.env.secrets` for sensitive values
